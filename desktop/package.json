{
  "name": "photo-watermark-remover-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Offline desktop app shell for local watermark removal",
  "main": "src/main/main.js",
  "scripts": {
    "prepare:models": "node ./scripts/prepare_models.js",
    "prepare:runtime": "node ./scripts/prepare_python_runtime.js",
    "prepare:package": "npm run prepare:models && npm run prepare:runtime",
    "prestart": "npm run prepare:models",
    "start": "electron .",
    "start:dev": "cross-env NODE_ENV=development electron .",
    "dist:dir": "npm run prepare:package && electron-builder --dir",
    "dist:win": "npm run prepare:package && electron-builder --win nsis"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.local.photo-watermark-remover",
    "productName": "Photo Watermark Remover",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!tmp/**",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "../models",
        "to": "models"
      },
      {
        "from": "build-resources/python",
        "to": "python"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "SadmanMahi67",
      "repo": "Photo-Watermark-Remover"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
